#!/usr/bin/env bash
#
# Pre-commit hook voor het AppSys-template-project.
#
# Activeren (gebeurt automatisch via postinstall):
#   git config core.hooksPath scripts/git-hooks
#
# Wat we checken op de STAGED changes (frontend/src + backend/src):
#   1. Em-dashes (U+2014). Verboden door docs/style-guide.md.
#   2. Curly quotes (U+201C/D, U+2018/9). LLM-tells.
#   3. AI-tell-emoji's en bliksemschicht-iconen (UX-DESIGN.md).
#   4. Hardcoded hex-kleuren in .vue/.ts (alleen tailwind.config + style.css mogen).
#   5. Geblokkeerde Tailwind-kleur-classes (alleen brand.* / gray-* / slate-* / white / black).
#   6. ESLint over staged files (errors blokkeren commit).
#
# Bypass alleen bij absolute noodzaak: git commit --no-verify.

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

FAIL=0

# Verzamel staged tekst-files in scope (.vue, .ts, .tsx).
STAGED=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '^(frontend/src|backend/src)/.*\.(vue|ts|tsx)$' \
  | grep -vE '\.test\.[tj]sx?$|__tests__/' || true)

if [ -z "$STAGED" ]; then
  exit 0
fi

# Byte-strings voor non-ASCII chars (cross-platform werken zonder grep -P).
EMDASH=$'\xe2\x80\x94'
BOLT=$'\xe2\x9a\xa1'
LDQUO=$'\xe2\x80\x9c'
RDQUO=$'\xe2\x80\x9d'
LSQUO=$'\xe2\x80\x98'
RSQUO=$'\xe2\x80\x99'
EMOJI_LIGHTBULB=$'\xf0\x9f\x92\xa1'
EMOJI_HANDSHAKE=$'\xf0\x9f\xa4\x9d'
EMOJI_CLIPBOARD=$'\xf0\x9f\x93\x8b'
EMOJI_SPARKLES=$'\xe2\x9c\xa8'
EMOJI_ROCKET=$'\xf0\x9f\x9a\x80'
EMOJI_FIRE=$'\xf0\x9f\x94\xa5'
EMOJI_STAR=$'\xe2\xad\x90'
EMOJI_CHECK_BOX=$'\xe2\x9c\x85'
EMOJI_CROSS_BOX=$'\xe2\x9d\x8c'
EMOJI_CHECK=$'\xe2\x9c\x93'
EMOJI_WARN=$'\xe2\x9a\xa0'

# ---------- 1. Em-dashes ----------
EMDASH_HITS=""
for f in $STAGED; do
  if [ -f "$f" ]; then
    HITS=$(grep -nF "$EMDASH" "$f" || true)
    if [ -n "$HITS" ]; then
      EMDASH_HITS="${EMDASH_HITS}${f}:\n${HITS}\n\n"
    fi
  fi
done
if [ -n "$EMDASH_HITS" ]; then
  echo -e "${RED}[pre-commit] FAIL: em-dash (U+2014) gevonden in staged changes${NC}"
  echo -e "${YELLOW}Volgens docs/style-guide.md is U+2014 verboden. Vervang door komma, ':' of en-dash '-'.${NC}"
  echo
  echo -e "$EMDASH_HITS"
  FAIL=1
fi

# ---------- 2. Curly quotes ----------
CURLY_HITS=""
for f in $STAGED; do
  if [ -f "$f" ]; then
    HITS=$( { grep -nF "$LDQUO" "$f"; grep -nF "$RDQUO" "$f"; grep -nF "$LSQUO" "$f"; grep -nF "$RSQUO" "$f"; } 2>/dev/null || true)
    if [ -n "$HITS" ]; then
      CURLY_HITS="${CURLY_HITS}${f}:\n${HITS}\n\n"
    fi
  fi
done
if [ -n "$CURLY_HITS" ]; then
  echo -e "${RED}[pre-commit] FAIL: typografische quotes (U+201C/D, U+2018/9) gevonden${NC}"
  echo -e "${YELLOW}Gebruik rechte quotes (\" en ').${NC}"
  echo
  echo -e "$CURLY_HITS"
  FAIL=1
fi

# ---------- 3. AI-tell-emoji's en bliksem ----------
EMOJI_PATTERNS=(
  "$BOLT" "$EMOJI_LIGHTBULB" "$EMOJI_HANDSHAKE" "$EMOJI_CLIPBOARD"
  "$EMOJI_SPARKLES" "$EMOJI_ROCKET" "$EMOJI_FIRE" "$EMOJI_STAR"
  "$EMOJI_CHECK_BOX" "$EMOJI_CROSS_BOX" "$EMOJI_CHECK" "$EMOJI_WARN"
)
EMOJI_HITS=""
for f in $STAGED; do
  if [ -f "$f" ]; then
    HITS=""
    for p in "${EMOJI_PATTERNS[@]}"; do
      H=$(grep -nF "$p" "$f" 2>/dev/null || true)
      if [ -n "$H" ]; then HITS="${HITS}${H}\n"; fi
    done
    H=$(grep -nE 'BoltIcon|LightningBoltIcon|ZapIcon' "$f" 2>/dev/null || true)
    if [ -n "$H" ]; then HITS="${HITS}${H}\n"; fi
    if [ -n "$HITS" ]; then
      EMOJI_HITS="${EMOJI_HITS}${f}:\n${HITS}\n"
    fi
  fi
done
if [ -n "$EMOJI_HITS" ]; then
  echo -e "${RED}[pre-commit] FAIL: AI-tell-emoji's of bliksemschicht-iconen gevonden${NC}"
  echo -e "${YELLOW}Volgens docs/UX-DESIGN.md: geen emoji-iconen of bliksemschicht-iconen op UI-elementen.${NC}"
  echo
  echo -e "$EMOJI_HITS"
  FAIL=1
fi

# ---------- 4. Hardcoded hex-kleuren in .vue/.ts ----------
# Tailwind config en style.css mogen hex bevatten; ook scoped <style>-blokken
# in .vue-files mogen het (dat is CSS). Hex in <template>/<script> van .vue,
# of in .ts/.tsx, blijft verboden.
HEX_HITS=""
for f in $STAGED; do
  if [ -f "$f" ]; then
    case "$f" in
      *tailwind.config.*|*style.css|*tokens.css|*public/brand/*) continue ;;
    esac
    case "$f" in
      *.vue)
        HITS=$(awk '
          /<style[^>]*>/ { in_style=1; next }
          /<\/style>/    { in_style=0; next }
          !in_style && /#[0-9a-fA-F]{3,8}/ { print NR": "$0 }
        ' "$f")
        ;;
      *)
        HITS=$(grep -nE '#[0-9a-fA-F]{3,8}\b' "$f" 2>/dev/null | grep -vE '#\{|#!' || true)
        ;;
    esac
    if [ -n "$HITS" ]; then
      HEX_HITS="${HEX_HITS}${f}:\n${HITS}\n\n"
    fi
  fi
done
if [ -n "$HEX_HITS" ]; then
  echo -e "${RED}[pre-commit] FAIL: hardcoded hex-kleur(en) gevonden buiten tailwind.config / style.css${NC}"
  echo -e "${YELLOW}Gebruik brand.* / gray-* Tailwind-tokens. Hex hoort in tailwind.config.js, style.css of public/brand/*.${NC}"
  echo
  echo -e "$HEX_HITS"
  FAIL=1
fi

# ---------- 5. Geblokkeerde Tailwind-kleur-classes ----------
# Pakt class="bg-blue-500", :class="'text-blue-700'", style binding etc.
# Whitelist: brand-*, gray-*, slate-*, red-* (voor error-states),
# white, black, transparent, current. Alleen rode tinten zijn toegestaan
# omdat error-states universeel rood zijn (a11y-conventie).
COLORS='orange|amber|yellow|lime|green|emerald|teal|cyan|sky|blue|indigo|violet|purple|fuchsia|pink|rose'
PROPS='bg|text|border|from|to|via|ring|divide|placeholder|caret|outline|fill|stroke|shadow'
TW_HITS=""
for f in $STAGED; do
  if [ -f "$f" ]; then
    HITS=$(grep -nE "\b(${PROPS})-(${COLORS})-[0-9]+\b" "$f" 2>/dev/null || true)
    if [ -n "$HITS" ]; then
      TW_HITS="${TW_HITS}${f}:\n${HITS}\n\n"
    fi
  fi
done
if [ -n "$TW_HITS" ]; then
  echo -e "${RED}[pre-commit] FAIL: geblokkeerde Tailwind-kleur-classes gevonden${NC}"
  echo -e "${YELLOW}Alleen brand.* / gray-* / slate-* / white / black mogen. Zie docs/UX-DESIGN.md.${NC}"
  echo
  echo -e "$TW_HITS"
  FAIL=1
fi

# ---------- 6. ESLint over staged files ----------
# Splits in BE en FE, run elk in zijn eigen werkmap zodat de juiste config laadt.
LINT_FAIL=0
BE_FILES=$(echo "$STAGED" | grep -E '^backend/src/' | sed 's|^backend/||' || true)
FE_FILES=$(echo "$STAGED" | grep -E '^frontend/src/' | sed 's|^frontend/||' || true)

if [ -n "$BE_FILES" ] && [ -d backend/node_modules/eslint ]; then
  if ! (cd backend && npx --no-install eslint --max-warnings=0 $BE_FILES); then
    LINT_FAIL=1
  fi
fi
if [ -n "$FE_FILES" ] && [ -d frontend/node_modules/eslint ]; then
  if ! (cd frontend && npx --no-install eslint --max-warnings=0 $FE_FILES); then
    LINT_FAIL=1
  fi
fi
if [ $LINT_FAIL -eq 1 ]; then
  echo -e "${RED}[pre-commit] FAIL: ESLint-errors. Fix met 'npm run lint:fix' of handmatig.${NC}"
  FAIL=1
fi

if [ $FAIL -eq 1 ]; then
  echo -e "${RED}Commit geweigerd. Fix bovenstaande issues en stage opnieuw.${NC}"
  echo -e "${YELLOW}Bypass (alleen bij absolute noodzaak): git commit --no-verify${NC}"
  exit 1
fi

echo -e "${GREEN}[pre-commit] OK${NC}"
exit 0
